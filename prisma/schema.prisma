generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  
}

enum ItemStatus {
  PendingApproval
  Tersedia
  Diambil
  Ditolak
}

enum Gender {
  Pria
  Wanita
}

enum ItemQuality {
  SangatBaik
  Baik
  CukupBaik
  Layak
  CukupLayak
}

enum ShipmentStatus {
  Pending
  Approved
  Rejected
  Delivered
}

model user {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique(map: "User_email_key")
  password    String
  poin        Int           @default(0)
  createdAt   DateTime      @default(now())
  profile     userProfile?
  certificate certificate[]
  item        item[]
  shipment    shipment[]
}

model userProfile {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  namaLengkap  String
  phone        String
  pekerjaan    String?
  address      String
  usia         Int
  gender       Gender
  identityId   String
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  verifiedBy   Int?
  user         user      @relation(fields: [userId], references: [id], map: "UserProfile_userId_fkey")
  shipment     shipment[]

  @@index([userId], map: "UserProfile_userId_fkey")
}

model admin {
  id       Int        @id @default(autoincrement())
  name     String
  email    String     @unique(map: "Admin_email_key")
  password String
  placeId  Int?
  place    place?      @relation(fields: [placeId], references: [id], map: "Admin_placeId_fkey")
  shipment shipment[]
  news     news[]

  @@index([placeId], map: "Admin_placeId_fkey")
}

model place {
  id             Int     @id @default(autoincrement())
  name           String
  address        String
  managerName    String
  managerPhone   String
  operationalJam String
  admin          admin[]
  item           item[]
}

model item {
  id          Int          @id @default(autoincrement())
  name        String
  category    String
  description String
  createdAt   DateTime     @default(now())
  userId      Int
  placeId     Int
  imageURL    String
  status      ItemStatus   @default(PendingApproval)
  quality     ItemQuality?
  user        user         @relation(fields: [userId], references: [id], map: "Item_userId_fkey")
  place       place        @relation(fields: [placeId], references: [id], map: "Item_placeId_fkey")
  shipment    shipment[]

  @@index([userId], map: "Item_userId_fkey")
  @@index([placeId], map: "Item_placeId_fkey")
}

model shipment {
  id              Int            @id @default(autoincrement())
  itemId          Int
  userId          Int
  adminId         Int?
  userProfileId   Int?
  type            String         // "donation" atau "claim"
  claimType       String?        // "pickup" atau "delivery"
  receivedAt      DateTime?
  receiverAddress String?
  isAutoApproved  Boolean        @default(false)
  status          ShipmentStatus @default(Pending)
  createdAt       DateTime       @default(now())
  deliveredDate   DateTime?

  item            item           @relation(fields: [itemId], references: [id], map: "Shipment_itemId_fkey")
  user            user           @relation(fields: [userId], references: [id], map: "Shipment_userId_fkey")
  admin           admin?         @relation(fields: [adminId], references: [id], map: "Shipment_adminId_fkey")
  userProfile     userProfile?   @relation(fields: [userProfileId], references: [id], map: "Shipment_userProfileId_fkey")

  @@unique([itemId, type])
  @@index([userId], map: "Shipment_userId_fkey_new")      
  @@index([adminId], map: "Shipment_adminId_fkey_new")    
  @@index([userProfileId], map: "Shipment_userProfileId_fkey_new") 
}

model certificate {
  id         Int      @id @default(autoincrement())
  receivedAt DateTime
  userId     Int
  user       user     @relation(fields: [userId], references: [id], map: "Certificate_userId_fkey")

  @@index([userId], map: "Certificate_userId_fkey")
}

model news {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  createdAt   DateTime @default(now())
  adminId      Int
  admin        admin     @relation(fields: [adminId], references: [id], map: "News_adminId_fkey")

  @@index([adminId], map: "News_adminId_fkey")
}
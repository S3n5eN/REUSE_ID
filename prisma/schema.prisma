generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model user {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique(map: "User_email_key")
  password    String
  poin        Int           @default(0)
  createdAt   DateTime      @default(now())
  certificate certificate[]
  item        item[]
  shipment    shipment[]
  userProfile userProfile?
}

model admin {
  id       Int        @id @default(autoincrement())
  name     String
  email    String     @unique(map: "Admin_email_key")
  password String
  placeId  Int?
  place    place?     @relation(fields: [placeId], references: [id], map: "Admin_placeId_fkey")
  news     news[]
  shipment shipment[]

  @@index([placeId], map: "Admin_placeId_fkey")
}

model place {
  id             Int     @id @default(autoincrement())
  name           String
  address        String
  managerName    String
  managerPhone   String
  operationalJam String
  latitude       Float?
  longitude      Float?
  admin          admin[]
  item           item[]
}

model item {
  id          Int          @id @default(autoincrement())
  name        String
  category    String
  description String
  createdAt   DateTime     @default(now())
  userId      Int
  placeId     Int
  imageData   Bytes?
  imageType   String?
  status      ItemStatus   @default(PendingApproval)
  quality     ItemQuality?
  weight      Float?
  place       place        @relation(fields: [placeId], references: [id], map: "Item_placeId_fkey")
  user        user         @relation(fields: [userId], references: [id], map: "Item_userId_fkey")
  shipment    shipment[]

  @@index([userId], map: "Item_userId_fkey")
  @@index([placeId], map: "Item_placeId_fkey")
}

model shipment {
  id              Int            @id @default(autoincrement())
  itemId          Int
  userId          Int
  adminId         Int?
  userProfileId   Int?
  type            String
  claimType       String?
  receivedAt      DateTime?
  receiverAddress String?
  isAutoApproved  Boolean        @default(false)
  status          ShipmentStatus @default(Pending)
  createdAt       DateTime       @default(now())
  deliveredDate   DateTime?
  shipmentCost    Int?
  distance        Float?
  deliveryLat     Float?
  deliveryLng     Float?
  admin           admin?         @relation(fields: [adminId], references: [id], map: "Shipment_adminId_fkey")
  item            item           @relation(fields: [itemId], references: [id], map: "Shipment_itemId_fkey")
  user            user           @relation(fields: [userId], references: [id], map: "Shipment_userId_fkey")
  userProfile     userProfile?   @relation(fields: [userProfileId], references: [id], map: "Shipment_userProfileId_fkey")

  @@unique([itemId, type])
  @@index([userId], map: "Shipment_userId_fkey_new")
  @@index([adminId], map: "Shipment_adminId_fkey_new")
  @@index([userProfileId], map: "Shipment_userProfileId_fkey_new")
}

model certificate {
  id         Int      @id @default(autoincrement())
  receivedAt DateTime
  userId     Int
  user       user     @relation(fields: [userId], references: [id], map: "Certificate_userId_fkey")

  @@index([userId], map: "Certificate_userId_fkey")
}

model news {
  id        Int      @id @default(autoincrement())
  title     String
  imageData Bytes
  imageType String
  createdAt DateTime @default(now())
  adminId   Int
  admin     admin    @relation(fields: [adminId], references: [id], map: "News_adminId_fkey")

  @@index([adminId], map: "News_adminId_fkey")
}

model userProfile {
  id          Int                @id @default(autoincrement())
  userId      Int                @unique(map: "userProfile_userId_key")
  namaLengkap String
  phone       String
  pekerjaan   String?
  address     String
  usia        Int
  gender      userProfile_gender
  identityId  String
  isVerified  Boolean            @default(false)
  verifiedAt  DateTime?
  verifiedBy  Int?
  latitude    Float?
  longitude   Float?
  shipment    shipment[]
  user        user               @relation(fields: [userId], references: [id], map: "UserProfile_userId_fkey")

  @@index([userId], map: "UserProfile_userId_fkey")
}

enum ItemStatus {
  PendingApproval
  Tersedia
  Diambil
  Ditolak
}

enum ItemQuality {
  SangatBaik
  Baik
  CukupBaik
  Layak
  CukupLayak
}

enum ShipmentStatus {
  Pending
  Approved
  Rejected
  Delivered
}

enum userProfile_gender {
  Pria
  Wanita
}

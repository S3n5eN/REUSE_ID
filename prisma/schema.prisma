generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique(map: "User_email_key")
  password    String
  poin        Int           @default(0)
  createdAt   DateTime      @default(now())
  certificate certificate[]
  item        item[]
  shipment    shipment[]
  userProfile userProfile?
  newsRead    newsRead[]
}

model admin {
  id       Int        @id @default(autoincrement())
  name     String
  email    String     @unique(map: "Admin_email_key")
  password String
  place    place[]
  news     news[]
  shipment shipment[]
}

model place {
  id             Int     @id @default(autoincrement())
  name           String
  address        String
  managerName    String
  managerPhone   String
  operationalJam String
  keyLocation    String
  latitude       Float?
  longitude      Float?
  admin          admin[]
  item           item[]
  rak            rak[]
}

model item {
  id          Int          @id @default(autoincrement())
  name        String
  category    String
  description String
  createdAt   DateTime     @default(now())
  userId      Int
  placeId     Int
  imageData   Bytes?
  imageType   String?
  rakId       Int?
  status      ItemStatus   @default(PendingApproval)
  quality     ItemQuality?
  weight      Float?
  place       place        @relation(fields: [placeId], references: [id])
  user        user         @relation(fields: [userId], references: [id])
  rak         rak?         @relation(fields: [rakId], references: [id])
  shipment    shipment[]

  @@index([userId], map: "Item_userId_fkey")
  @@index([placeId], map: "Item_placeId_fkey")
  @@index([rakId], map: "Item_rakId_fkey")
}

model rak {
  id    Int @id @default(autoincrement())
  nomor String
  kapasitasMax Int
  kapasitasSekarang Int @default(0)
  placeId Int
  place place @relation(fields: [placeId], references: [id])
  item item[]

  @@index([placeId])
}

model shipment {
  id              Int            @id @default(autoincrement())
  itemId          Int
  userId          Int
  adminId         Int?
  userProfileId   Int?
  type            String
  claimType       String?
  receivedAt      DateTime?
  receiverAddress String?
  isAutoApproved  Boolean        @default(false)
  status          ShipmentStatus @default(Pending)
  createdAt       DateTime       @default(now())
  deliveredDate   DateTime?
  shipmentCost    Int?
  paymentInvoice  String?
  paymentTotal    Int?
  paymentExpiredAt DateTime?
  distance        Float?
  deliveryLat     Float?
  deliveryLng     Float?
  paymentMethod   String?       // "ATM"
  paymentStatus   PaymentStatus @default(Unpaid)
  transferBankCode String?
  transferBankName String?
  transferAccountNumber String?
  transferAccountHolder String?
  payerBank       String?
  payerAccountName String?
  transferProofImage Bytes?
  transferProofType String?
  transferProofUploadedAt DateTime?
  paymentVerifiedAt DateTime?

  admin           admin?         @relation(fields: [adminId], references: [id], map: "Shipment_adminId_fkey")
  item            item           @relation(fields: [itemId], references: [id], map: "Shipment_itemId_fkey")
  user            user           @relation(fields: [userId], references: [id], map: "Shipment_userId_fkey")
  userProfile     userProfile?   @relation(fields: [userProfileId], references: [id], map: "Shipment_userProfileId_fkey")

  @@unique([itemId, type])
  @@index([userId], map: "Shipment_userId_fkey_new")
  @@index([adminId], map: "Shipment_adminId_fkey_new")
  @@index([userProfileId], map: "Shipment_userProfileId_fkey_new")
}

model certificate {
  id         Int      @id @default(autoincrement())
  receivedAt DateTime
  userId     Int
  user       user     @relation(fields: [userId], references: [id])

  @@index([userId], map: "Certificate_userId_fkey")
}

model news {
  id          Int      @id @default(autoincrement())
  title       String
  caption     String?    @db.Text
  imageData   Bytes
  imageType   String
  createdAt   DateTime @default(now())
  isPublished Boolean  @default(false)
  adminId     Int
  admin       admin    @relation(fields: [adminId], references: [id])
  newsRead    newsRead[]

  @@index([adminId], map: "News_adminId_fkey")
}

model newsRead {
  id        Int      @id @default(autoincrement())
  userId    Int
  newsId    Int
  readAt    DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id])
  news      news     @relation(fields: [newsId], references: [id])

  @@unique([userId, newsId])
  @@index([userId])
  @@index([newsId])
}

model userProfile {
  id          Int                @id @default(autoincrement())
  userId      Int                @unique(map: "userProfile_userId_key")
  namaLengkap String
  phone       String
  address     String
  usia        Int
  gender      userProfile_gender
  identityId  String
  isVerified  Boolean            @default(false)
  verifiedAt  DateTime?
  verifiedBy  Int?
  latitude    Float?
  longitude   Float?
  shipment    shipment[]
  user        user               @relation(fields: [userId], references: [id])
  profileImage Bytes?
  profileImageType String?

  @@index([userId], map: "UserProfile_userId_fkey")
}

model passwordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum ItemStatus {
  PendingApproval
  Tersedia
  Diambil
  Ditolak
}

enum ItemQuality {
  SangatBaik
  Baik
  CukupBaik
  Layak
  CukupLayak
}

enum ShipmentStatus {
  Pending
  Approved
  Delivered
}

enum userProfile_gender {
  Pria
  Wanita
}

enum PaymentStatus {        
  Unpaid
  WaitingVerification
  Paid
  Failed
}
